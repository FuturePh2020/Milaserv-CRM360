# Environment variables for the Vercel project (apps/web).
# Set these in Vercel Project Settings -> Environment Variables. All
# NEXT_PUBLIC_* values are inlined into the client bundle at *build* time -
# changing them requires a redeploy, not just a runtime restart.

# Same-origin API path - the browser only ever calls /api/*, which
# next.config.mjs rewrites server-side to API_ORIGIN below.
NEXT_PUBLIC_API_URL=/api

# The real Render API URL, no trailing slash. Used only by the rewrite in
# next.config.mjs (server-side), never sent to the browser directly.
API_ORIGIN=https://REPLACE_ME.onrender.com

# Shows the amber "DEMO ENVIRONMENT" banner and the test-data-only import
# confirmation gate (see apps/web/src/components/ActivityTracker.tsx's
# sibling demo-mode pieces in AppShell.tsx / ImportUploadFlow.tsx).
NEXT_PUBLIC_DEMO_MODE=true

# Milaserv CRM360 - environment configuration template
# Copy to .env for local development. Never commit real secrets.

# ---- General ----
NODE_ENV=development
APP_TIMEZONE=Africa/Cairo
APP_NAME="Milaserv CRM360"

# ---- Database ----
POSTGRES_USER=milaserv
POSTGRES_PASSWORD=change_me
POSTGRES_DB=milaserv_crm360
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# connection_limit: Prisma's default pool is small (num_cpus*2+1) - a live
# concurrency test in this repo's history (55 simultaneous Generate Lead
# calls) hit "Transaction already closed" errors under the default pool
# before this was added. Size it for the target ~200 concurrent Agents in
# staging/production, not just local dev.
DATABASE_URL=postgresql://milaserv:change_me@localhost:5432/milaserv_crm360?schema=public&connection_limit=60&pool_timeout=20

# ---- Redis / BullMQ ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- API ----
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# ---- Auth ----
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_TTL=7d
AUTH_COOKIE_DOMAIN=localhost
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_WINDOW_MINUTES=15
AUTH_LOCKOUT_DURATION_MINUTES=15

# ---- Seed Team Leader (initial admin) ----
SEED_TEAM_LEADER_EMAIL=admin@milaserv.local
SEED_TEAM_LEADER_PASSWORD=change_me_strong_password
SEED_TEAM_LEADER_FULL_NAME="Milaserv Admin"

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ---- Uploads ----
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_STORAGE_PATH=./storage/uploads
UPLOAD_ALLOWED_MIME_TYPES=application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv

# ---- Device / Activity Companion ----
DEVICE_TOKEN_SECRET=change_me_device_secret
IDLE_BREAK_THRESHOLD_SECONDS=300

# ---- CDR ----
CDR_DEFAULT_SOURCE_TIMEZONE=Asia/Riyadh

# ---- Worker ----
WORKER_CONCURRENCY=5

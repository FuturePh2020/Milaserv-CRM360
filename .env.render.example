# Environment variables for the Render web service (milaserv-crm360-api).
# This file documents every variable render.yaml references - it is NOT
# loaded automatically by the app (Render injects real env vars directly,
# no .env file involved in that environment). Copy values into the Render
# dashboard, never into a committed file.

# ---- Supabase Postgres ----
# Supabase dashboard -> Project Settings -> Database -> Connection string
# (URI) -> "Transaction" pooler mode is recommended for a serverless-style
# free-tier web service. Append connection_limit for Prisma the same way
# local dev does (see .env.example's note on this).
DATABASE_URL=postgresql://postgres.xxxxxxxx:REPLACE_ME@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5

# ---- Upstash Redis (TLS required) ----
# Upstash console -> your database -> "Endpoint" (host, no scheme) and
# "Password". REDIS_TLS must stay "true" - Upstash rejects plain TCP.
REDIS_HOST=REPLACE_ME.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_ME
REDIS_TLS=true

# ---- Auth secrets ----
# Leave unset in the dashboard and let Render generate these
# (generateValue: true in render.yaml) rather than pasting a value here -
# this file exists to document names, not to carry real secrets.
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_TTL=7d
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_WINDOW_MINUTES=15
AUTH_LOCKOUT_DURATION_MINUTES=15

# ---- CORS ----
# The exact Vercel deployment URL(s), comma-separated for more than one.
# Same-origin traffic through the Vercel /api rewrite doesn't need this,
# but keep it correct anyway for any direct-to-API request path.
CORS_ORIGIN=https://REPLACE_ME.vercel.app

# ---- Seed (first deploy only) ----
SEED_TEAM_LEADER_EMAIL=admin@REPLACE_ME.example
SEED_TEAM_LEADER_PASSWORD=REPLACE_ME_STRONG_PASSWORD
SEED_TEAM_LEADER_FULL_NAME=Demo Admin

# ---- Uploads ----
# Render's free-tier disk is ephemeral - see render.yaml's comment and
# docs/deployment/FREE_PUBLIC_DEMO_CLOUD.md's Known Limitations for the
# Supabase Storage follow-up this does not yet wire up.
UPLOAD_STORAGE_PATH=/tmp/uploads
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_ALLOWED_MIME_TYPES=application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/csv

# ---- App defaults ----
CDR_DEFAULT_SOURCE_TIMEZONE=Asia/Riyadh
DASHBOARD_BREAK_ALLOWANCE_MINUTES=60
DASHBOARD_OVERVIEW_CACHE_TTL_SECONDS=10
IDLE_BREAK_THRESHOLD_SECONDS=300
APP_TIMEZONE=Africa/Cairo
WORKER_CONCURRENCY=5
NODE_ENV=production

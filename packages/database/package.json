{
  "name": "@milaserv/database",
  "version": "0.1.0",
  "private": true,
  "main": "generated/client/index.js",
  "types": "generated/client/index.d.ts",
  "scripts": {
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts",
    "build": "prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\""
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "prisma": "^5.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "argon2": "^0.41.1",
    "dotenv-cli": "^7.4.2",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^8.57.1"
  }
}

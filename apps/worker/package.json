{
  "name": "@milaserv/worker",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "dotenv -e ../../.env -- ts-node-dev --respawn src/main.ts",
    "build": "tsc -p tsconfig.json",

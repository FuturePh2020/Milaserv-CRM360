  },
  "devDependencies": {
    "@milaserv/config": "workspace:*",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.5",
    "dotenv-cli": "^7.4.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
